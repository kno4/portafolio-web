---
interface Props {
  title: string;
  enTitle?: string;
  description: string;
  enDescription?: string;
  role: string;
  enRole?: string;
  tags: string[];
  repoUrl?: string;
  index: number;
}

const { title, enTitle, description, enDescription, role, enRole, tags, repoUrl, index } = Astro.props;
const formattedIndex = String(index).padStart(2, '0');
---

<article class="group relative overflow-hidden bg-[#141414] border border-[#333] hover:border-[#c49a3c] p-6 transition-colors duration-300">
  <!-- Header row -->
  <div class="flex justify-between items-start mb-4">
    <span class="text-[10px] font-['JetBrains_Mono'] uppercase tracking-widest text-[#c49a3c] border border-[#c49a3c33] px-2 py-0.5">
      <span class="lang-es">{role}</span>
      <span class="lang-en">{enRole || role}</span>
    </span>
    <span class="font-['JetBrains_Mono'] text-3xl font-bold text-[#222] group-hover:text-[#c49a3c22] transition-colors duration-300">
      {formattedIndex}
    </span>
  </div>

  <!-- Title -->
  <h3 class="font-['JetBrains_Mono'] text-lg text-[#e0e0e0] font-medium mb-3">
    <span class="lang-es">{title}</span>
    <span class="lang-en">{enTitle || title}</span>
  </h3>

  <!-- Description -->
  <p class="font-['Inter'] text-sm text-[#888] leading-relaxed mb-5">
    <span class="lang-es">{description}</span>
    <span class="lang-en">{enDescription || description}</span>
  </p>

  <!-- Tags & Links -->
  <div class="flex flex-col gap-4 mt-auto pt-4">
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="inline-block px-2 py-0.5 text-[10px] font-['JetBrains_Mono'] border border-[#333] text-[#666] hover:border-[#c49a3c] hover:text-[#c49a3c] transition-colors duration-200">
          {tag}
        </span>
      ))}
    </div>
    
    {repoUrl && (
      <div class="flex items-center">
        <a 
          href={repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-3 py-1 text-xs font-['JetBrains_Mono'] text-[#888] border border-[#333] hover:text-[#c49a3c] hover:border-[#c49a3c] transition-colors duration-200"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          <span class="lang-es">Ver Repo</span>
          <span class="lang-en">View Repo</span>
        </a>
      </div>
    )}
  </div>

  <!-- Decorative corner accent -->
  <div class="absolute bottom-0 right-0">
    <div class="w-6 h-px bg-[#333] group-hover:bg-[#c49a3c] transition-colors duration-300"></div>
    <div class="w-px h-6 bg-[#333] group-hover:bg-[#c49a3c] transition-colors duration-300 ml-auto"></div>
  </div>
</article>
